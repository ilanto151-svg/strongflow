# Server configuration
PORT=4000
JWT_SECRET=your-super-secret-jwt-key-change-this

# Optional: SMTP for email-based password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=OncoMove <your@gmail.com>

# Optional: Frontend URL for CORS (set to your Railway domain)
CLIENT_URL=https://your-app.railway.app

# Google Drive upload (optional)
# Create OAuth2 credentials at https://console.cloud.google.com
# Add your Railway domain to the Authorized JavaScript Origins
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
